APP_ENV=development
WEB_PORT=3000
API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Local uv backend + Docker infrastructure mode.
# The FastAPI process runs on the host, so service addresses must use localhost.
POSTGRES_DB=agentflow
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow
DATABASE_URL=postgresql+psycopg://agentflow:agentflow@localhost:5432/agentflow
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=agentflow
MINIO_SECRET_KEY=agentflow123
MINIO_BUCKET=agentflow

JWT_SECRET_KEY=change-me-in-production
API_KEY_ENCRYPTION_SECRET=change-me-32-bytes-secret
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
