{
  "name": "agentflow-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Enterprise AI Agent workflow and knowledge base platform",
  "scripts": {
    "dev:web": "pnpm --filter @agentflow/web dev",
    "build:web": "pnpm --filter @agentflow/web build",
    "lint:web": "pnpm --filter @agentflow/web lint",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
